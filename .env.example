# ServiceNow "Ownership API" Scripted REST Service.
# Leave these unset to run the workspace against the built-in mock data store.
SERVICENOW_URL=
SERVICENOW_USERNAME=
SERVICENOW_PASSWORD=
# Base path of the Scripted REST API in Studio (defaults to /api/x_cmdb_ownership/ownership).
SERVICENOW_API_PATH=

# Demo-tier auth (planning.md "Simple API Key Authentication").
# Set a distinct access key per role and a long random SESSION_SECRET
# (e.g. `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`).
STEWARD_API_KEY=
# Optional legacy viewer key. The login page now allows keyless read-only access.
VIEWER_API_KEY=
SESSION_SECRET=
